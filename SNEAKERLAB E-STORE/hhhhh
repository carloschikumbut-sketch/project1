// 1. DASHBOARD INITIALIZATION (KPIs & Charts)
async function initDashboard() {
    try {
        const { data: orders, error } = await _supabase.from('orders').select('*');
        if (error) throw error;

        let totalSales = 0;
        let orderCount = orders.length;
        let productPerformance = {};

        orders.forEach(order => {
            totalSales += parseFloat(order.total_price || 0);
            if (order.items && Array.isArray(order.items)) {
                order.items.forEach(item => {
                    const price = typeof item.price === 'string' ? parseFloat(item.price.replace('$', '')) : item.price;
                    productPerformance[item.name] = (productPerformance[item.name] || 0) + (price * (item.quantity || 1));
                });
            }
        });

        if(document.getElementById('total-sales')) document.getElementById('total-sales').innerText = `$${totalSales.toLocaleString()}`;
        if(document.getElementById('total-orders')) document.getElementById('total-orders').innerText = orderCount;
        if(document.getElementById('aov')) document.getElementById('aov').innerText = `$${(totalSales / orderCount || 0).toFixed(2)}`;

        renderProductChart(productPerformance);
    } catch (err) {
        console.error("Dashboard Load Error:", err.message);
    }
}

// 2. CHART RENDERING
function renderProductChart(data) {
    const chartCanvas = document.getElementById('topProductsBarChart');
    if (!chartCanvas) return;
    const ctx = chartCanvas.getContext('2d');
    const sorted = Object.entries(data).sort((a, b) => b[1] - a[1]).slice(0, 5);

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: sorted.map(i => i[0]),
            datasets: [{ label: 'Revenue', data: sorted.map(i => i[1]), backgroundColor: '#008060' }]
        },
        options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false }
    });
}

// 3. INVENTORY MANAGEMENT (Load, Edit, Delete)
async function refreshInventoryList() {
    const listBody = document.getElementById('inventory-list-body');
    if (!listBody) return;

    const { data: products, error } = await _supabase
        .from('products')
        .select('*')
        .order('created_at', { ascending: false });

    if (error) {
        console.error("Error fetching inventory:", error);
        return;
    }

    listBody.innerHTML = products.map(product => `
        <tr>
            <td><img src="${product.image_url}" width="40" style="border-radius:4px;"></td>
            <td><strong>${product.name}</strong></td>
            <td>$${product.price}</td>
            <td>
                <button onclick="editProductPrice(${product.id}, ${product.price})" style="color:#008060; background:none; border:none; cursor:pointer; margin-right:10px;">
                    <i class="fa-solid fa-pen-to-square"></i>
                </button>
                <button onclick="deleteProduct(${product.id})" style="color:#d72c0d; background:none; border:none; cursor:pointer;">
                    <i class="fa-solid fa-trash-can"></i>
                </button>
            </td>
        </tr>
    `).join('');
} // <--- THIS WAS THE MISSING BRACE

async function deleteProduct(productId) {
    if (!confirm("Are you sure you want to remove this sneaker?")) return;
    const { error } = await _supabase.from('products').delete().eq('id', productId);
    if (error) {
        showToast("Delete failed: " + error.message, "error");
    } else {
        showToast("Product removed!", "success");
        refreshInventoryList();
    }
}

async function editProductPrice(productId, oldPrice) {
    const newPrice = prompt(`Update price:`, oldPrice);
    if (newPrice === null || isNaN(newPrice) || newPrice === "") return;

    const { error } = await _supabase
        .from('products')
        .update({ price: parseFloat(newPrice) })
        .eq('id', productId);

    if (error) {
        showToast("Update failed: " + error.message, "error");
    } else {
        showToast("Price updated!", "success");
        refreshInventoryList();
    }
}

// 4. SUPABASE INSERT LOGIC
async function addSneakerToSupabase(name, price, brand, imgUrl, desc, cat) {
    const { data, error } = await _supabase
        .from('products')
        .insert([{ 
            name: name, price: parseFloat(price), brand: brand, 
            image_url: imgUrl, description: desc, category: cat 
        }]);

    if (error) {
        alert("Error: " + error.message);
    } else {
        showToast("Sneaker added!", "success");
        refreshInventoryList(); // Update the list immediately
    }
}

// 5. GLOBAL INITIALIZATION
document.addEventListener('DOMContentLoaded', () => {
    const inventoryForm = document.getElementById('inventory-form');
    if (inventoryForm) {
        inventoryForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const title = document.getElementById('prod-title').value;
            const price = document.getElementById('prod-price').value;
            const brand = document.getElementById('prod-brand').value;
            const imgUrl = document.getElementById('prod-img-url').value;
            const desc = document.getElementById('prod-desc').value;
            const cat = document.getElementById('prod-cat').value;

            await addSneakerToSupabase(title, price, brand, imgUrl, desc, cat);
            inventoryForm.reset();
        });
    }

    refreshInventoryList();
    if (document.getElementById('total-sales')) initDashboard();
});


